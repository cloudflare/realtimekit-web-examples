{
  "name": "html-examples",
  "scripts": {
    "format": "prettier -w examples",
    "update-cloudflare-realtime-deps": "./update-cloudflare-realtime-deps.sh",
    "set-env": "bash scripts/set-env.sh",
    "prebuild": "bash scripts/set-env.sh",
    "build": "bash -c 'npm run prebuild && npm run update-cloudflare-realtime-deps -- \"$@\" && npm run postbuild' -- \"$@\"",
    "postbuild": "./postbuild.sh",
    "deploy": "wrangler deploy",
    "dev": "npm run prebuild && npx serve examples/default-meeting-ui"
  },
  "prettier": {
    "singleQuote": true,
    "proseWrap": "always"
  },
  "devDependencies": {
    "prettier": "^2.8.1"
  },
  "dependencies": {
    "serve": "^14.1.2",
    "@cloudflare/kv-asset-handler": "^0.4.0"
  
  }
}
